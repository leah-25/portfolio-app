# Copy this file to .env.local and fill in your key.
# .env.local is git-ignored — the key never enters version control or the browser bundle.

# Your Anthropic API key (https://console.anthropic.com)
# No VITE_ prefix → NOT bundled into the browser JS.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Tell the frontend to route analysis requests through the /api/analyze proxy
# instead of calling Anthropic directly from the browser.
VITE_USE_SERVER_KEY=true
