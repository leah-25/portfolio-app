{
  "buildCommand": "cd app && npm install && npm run build",
  "outputDirectory": "app/dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "app/api/analyze.ts":  { "maxDuration": 60 },
    "app/api/generate.ts": { "maxDuration": 60 }
  }
}
